# ════════════════════════════════════════════════════════════════
# FitSync Backend — Environment Variables
# ════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` to git — it's already in .gitignore.
# ════════════════════════════════════════════════════════════════


# ─── Core ────────────────────────────────────────────────────────
# Port the server listens on. Leave as 5000 for local dev.
PORT=5000

# Environment: "development" or "production"
# - development → coloured logs to console, error stack traces in responses
# - production  → logs to logs/access.log, generic 500 messages, no stack traces
NODE_ENV=development


# ─── Database ────────────────────────────────────────────────────
# MongoDB connection string.
# Local:    mongodb://localhost:27017/fitsync
# Atlas:    mongodb+srv://USER:PASS@cluster.xyz.mongodb.net/fitsync?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/fitsync


# ─── Auth / JWT ──────────────────────────────────────────────────
# Secret used to sign JWTs. MUST be a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Access token lifetime. Long-lived (90 days) so users stay logged in
# through screen sleep, browser close/reopen, etc. — per guide feedback
# #1: "Do NOT auto-logout users due to inactivity or screen sleep."
# Tokens are still revoked on explicit logout (frontend clears storage).
# Format: '7d', '24h', '90d' — see https://github.com/vercel/ms
JWT_EXPIRE=90d


# ─── Frontend origin(s) for CORS ─────────────────────────────────
# The URL(s) where the frontend is served from.
# Local dev:   http://localhost:5173
# Production:  https://fitsync.example.com
# Multiple:    http://localhost:5173,https://fitsync.example.com (comma-separated)
CLIENT_URL=http://localhost:5173

# Some parts of the backend (email templates) also read FRONTEND_URL.
# Keep it in sync with CLIENT_URL's primary value.
FRONTEND_URL=http://localhost:5173


# ─── Email (Nodemailer / Gmail SMTP) ─────────────────────────────
# Leave blank to disable email entirely (OTP, password reset, invites
# will still work for demo — they just won't actually send).
#
# Gmail setup (recommended for development):
#   1. Enable 2-Step Verification on your Google account
#      https://myaccount.google.com/security
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#      (NOT your regular Gmail password — that won't work)
#   3. Set EMAIL_USER to the Gmail address
#      Set EMAIL_PASS to the 16-char App Password (no spaces)
#
# Other SMTP providers: this codebase uses `service: 'gmail'` in
# utils/email.js. To use SendGrid / AWS SES / Mailgun / etc., edit
# utils/email.js to use `host`/`port`/`secure` instead of `service`.
#
# See backend/EMAIL_SETUP.md for a step-by-step Gmail walkthrough.
EMAIL_USER=
EMAIL_PASS=
# Display name that appears in the "From:" field of outgoing emails
EMAIL_FROM_NAME=FitSync


# ─── Rate Limiting (optional — defaults shown) ───────────────────
# Tight limit for /api/auth/* — login, register, forgot-password
AUTH_RATE_LIMIT_MAX=20
AUTH_RATE_LIMIT_WINDOW_MS=900000

# General limit for all other /api/* endpoints
API_RATE_LIMIT_MAX=300
API_RATE_LIMIT_WINDOW_MS=900000


# ─── Proxy (production only) ─────────────────────────────────────
# Set to "true" if the app sits behind a reverse proxy (Nginx,
# Cloudflare, Render, Heroku, Fly, Railway). Required so rate
# limiting uses the real client IP instead of the proxy's IP.
TRUST_PROXY=false


# ─── Razorpay (optional, not yet wired up) ───────────────────────
# Only needed when you activate the Razorpay payment integration.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
